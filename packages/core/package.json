{
  "name": "rolloutjs",
  "version": "0.1.1",
  "description": "Feature flags and gradual rollout, powered by your app. Open-source, full-stack and framework-agnostic.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "screenshots"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepack": "node ./scripts/sync-readme.mjs prepare",
    "postpack": "node ./scripts/sync-readme.mjs clean"
  },
  "keywords": [],
  "author": "Edward Kang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edward-kng/rolloutjs.git"
  },
  "bugs": {
    "url": "https://github.com/edward-kng/rolloutjs/issues"
  },
  "packageManager": "pnpm@10.27.0",
  "dependencies": {
    "@openfeature/core": "^1.9.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "vitest": "^4.1.4"
  }
}
